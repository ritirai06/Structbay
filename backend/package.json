{
  "name": "structbay-backend",
  "version": "1.0.0",
  "description": "StructBay MERN Backend - Phase 2 Auth & Role Management",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch --runInBand",
    "test:coverage": "jest --coverage --runInBand --forceExit",
    "seed:roles": "node src/seeders/seed-roles.js",
    "seed:admin": "node src/seeders/create-admin.js",
    "seed:demo-product": "node src/seeders/seed-demo-variation-product.js",
    "cleanup:soft-deletes": "node src/seeders/cleanup-soft-deletes.js",
    "cleanup:cities": "node src/seeders/cleanup-cities.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop structbay-backend",
    "pm2:restart": "pm2 restart structbay-backend",
    "pm2:logs": "pm2 logs structbay-backend"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "setupFilesAfterFramework": [],
    "testTimeout": 30000
  },
  "keywords": [
    "structbay",
    "construction",
    "marketplace",
    "mern"
  ],
  "author": "StructBay",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.17.0",
    "bcryptjs": "^2.4.3",
    "bwip-js": "^4.11.1",
    "cloudinary": "^2.10.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.1",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.2",
    "nodemailer": "^8.0.10",
    "pdfkit": "^0.19.1",
    "qrcode": "^1.5.4",
    "slugify": "^1.6.6",
    "streamifier": "^0.1.1",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.0.0",
    "nodemon": "^3.1.3",
    "supertest": "^7.0.0"
  }
}
