# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development                  # development | production | test

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?appName=structbay

# ─── JWT (code uses JWT_ACCESS_SECRET — not JWT_SECRET) ───────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=<generate_64_byte_random_hex>
JWT_REFRESH_SECRET=<generate_64_byte_random_hex>
JWT_RESET_SECRET=<generate_64_byte_random_hex>
JWT_ACCESS_EXPIRES_IN=15m             # Access token lifespan
JWT_REFRESH_EXPIRES_IN=30d            # Refresh token lifespan (JWT claim)
JWT_REFRESH_EXPIRES_DAYS=30           # Refresh token lifespan (DB TTL, integer days)
JWT_RESET_EXPIRES_IN=1h               # Password reset token lifespan

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=<your_cloud_name>
CLOUDINARY_API_KEY=<your_api_key>
CLOUDINARY_API_SECRET=<your_api_secret>

# ─── Frontend URLs (CORS & email links) ──────────────────────────────────────
# Single SPA (Vite on 3000): point all panel URLs at the same origin so CORS allows the browser.
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3000
CUSTOMER_URL=http://localhost:3000
VENDOR_URL=http://localhost:3000

# ─── Email / SMTP ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false                     # true for port 465
SMTP_USER=<smtp_username>
SMTP_PASS=<smtp_password_or_app_password>
SMTP_FROM=StructBay <no-reply@structbay.com>

GMAIL_USER=<your_gmail_address>
GMAIL_PASS=<your_gmail_app_password>

# ─── Zoho (optional — Books / Inventory; see src/services/zoho.service.js) ───
# ZOHO_CLIENT_ID=
# ZOHO_CLIENT_SECRET=
# ZOHO_REFRESH_TOKEN=
# ZOHO_ACCOUNTS_URL=https://accounts.zoho.in
# ZOHO_ORG_ID=

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000           # 15 minutes in ms
RATE_LIMIT_MAX=100                    # Max requests per window per IP
