# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development                  # development | production | test

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Primary URI (often mongodb+srv:// from Atlas).
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/?appName=Cluster0
# If querySrv ECONNREFUSED on Windows: optional Atlas **standard** mongodb://host1:27017,host2:27017,...
# (no +srv). Tried after MONGODB_URI; see README.
MONGODB_URI_DIRECT=
# Optional: DNS servers for this Node process, comma-separated (try before SRV retry).
# Example: MONGODB_DNS_SERVERS=8.8.8.8,8.8.4.4
MONGODB_DNS_SERVERS=

# ─── JWT (code uses JWT_ACCESS_SECRET — not JWT_SECRET) ───────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=<generate_64_byte_random_hex>
JWT_REFRESH_SECRET=<generate_64_byte_random_hex>
JWT_RESET_SECRET=<generate_64_byte_random_hex>
JWT_ACCESS_EXPIRES_IN=15m             # Access token lifespan
JWT_REFRESH_EXPIRES_IN=30d            # Refresh token lifespan (JWT claim)
JWT_REFRESH_EXPIRES_DAYS=30           # Refresh token lifespan (DB TTL, integer days)
JWT_RESET_EXPIRES_IN=1h               # Password reset token lifespan

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=<your_cloud_name>
CLOUDINARY_API_KEY=<your_api_key>
CLOUDINARY_API_SECRET=<your_api_secret>

# ─── Frontend URLs (CORS & email links) ──────────────────────────────────────
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3000
CUSTOMER_URL=http://localhost:3000
VENDOR_URL=http://localhost:3000

# Optional: PNG used in customer order invoice HTML (embedded). Defaults to monorepo
# `frontend/shared/assets/logos/Structbay-Logo-F-1.png`. Set to a smaller file to reduce download size.
# INVOICE_LOGO_PATH=C:/path/to/structbay-logo-invoice.png

# ─── Email / SMTP (see src/services/email.service.js) ─────────────────────────
# Prefer explicit SMTP. Values are trimmed — avoid spaces after = (e.g. SMTP_USER=email@... not SMTP_USER= email@...).
# Gmail: use an App Password (Google Account → Security → 2-Step Verification → App passwords), not your normal login password.
# Zoho Mail (example India): SMTP_HOST=smtp.zoho.in, SMTP_USER=full@yourdomain.com, SMTP_PASS=Zoho SMTP / app password.
# If a password contains # or spaces, wrap the whole value in double quotes (otherwise # starts a comment in .env).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional fallback if SMTP_USER/SMTP_PASS are empty (same App Password works here)
GMAIL_USER=
GMAIL_PASS=

# Contact form email recipient (defaults to SMTP_FROM if not set)
CONTACT_FORM_EMAIL=hello@structbay.com

# Logo file path for email templates (optional — defaults to frontend/public/banner/Structbay logo.png)
# LOGO_FILE_PATH=/path/to/logo.png

# LOCAL / STAGING ONLY (never true in production): allow customer login without verified email while fixing SMTP.
# ALLOW_UNVERIFIED_CUSTOMER_LOGIN=true

# ─── Zoho (optional — Books / Inventory; see src/services/zoho.service.js) ───
# ZOHO_CLIENT_ID=
# ZOHO_CLIENT_SECRET=
# ZOHO_REFRESH_TOKEN=
# ZOHO_ACCOUNTS_URL=https://accounts.zoho.in
# ZOHO_ORG_ID=

# ─── Vendor registration ─────────────────────────────────────────────────────
# When false (default), POST /auth/register/vendor returns 403; vendors are created via POST /admin/vendors only.
# Set to true only if you need legacy public vendor self-signup.
ALLOW_PUBLIC_VENDOR_REGISTRATION=false

# ─── Bootstrap admin (optional — run `npm run seed:admin` once) ───────────────
SEED_ADMIN_EMAIL=admin@hsdadigital.com
SEED_ADMIN_PASSWORD=admin@123

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# Window (ms) and max hits per IP per window for /api (except auth has its own cap).
# In NODE_ENV=development, limits are skipped unless ENABLE_RATE_LIMIT_IN_DEV=true.
# Set DISABLE_RATE_LIMIT=true to turn off (emergency local only).
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=2000
# ENABLE_RATE_LIMIT_IN_DEV=true
# DISABLE_RATE_LIMIT=true
