# Base URL for API calls that use full origin (admin pages, RFQ, bulk enquiry, hooks).
# Example matches default backend from backend/README (port 5000, /api/v1 prefix).
VITE_API_URL=http://localhost:5000/api/v1

# Optional: Vite dev server proxy target for `/api/*` (defaults to http://127.0.0.1:5000).
# VITE_DEV_API_ORIGIN=http://127.0.0.1:5000
